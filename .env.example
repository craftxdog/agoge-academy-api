# 🏛️ Agoge Academy API - Environment Variables

# 🚀 App Configuration
PORT=3000
NODE_ENV=development

# 🗄️ Database (PostgreSQL)

# Format:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agoge?schema=public
# 🌐 CORS
# Frontend URL allowed to access the API
FRONTEND_URL=http://localhost:3000

# 🔐 JWT Authentication
# ⚠️ Use strong secrets in production
JWT_SECRET=your-access-token-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# 📦 Storage Configuration
# Options: s3 | local
STORAGE_PROVIDER=local
# Max upload size (MB)
MAX_FILE_SIZE_MB=10

# ☁️ AWS S3 (only if STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_S3_KEY_ID=your-access-key
AWS_SECRET_S3_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

# 💾 Local Storage (only if STORAGE_PROVIDER=local)
LOCAL_STORAGE_PATH=./uploads
