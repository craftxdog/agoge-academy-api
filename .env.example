# 🏛️ Agoge Academy API - Environment Variables

# 🚀 App Configuration
PORT=3000
NODE_ENV=development

# 🗄️ Database (PostgreSQL)

# Format:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agoge?schema=public
# 🌐 CORS
# Frontend URL allowed to access the API
FRONTEND_URL=http://localhost:3000

# 🔐 JWT Authentication
# ⚠️ Use strong secrets in production
JWT_SECRET=replace-with-a-strong-access-secret-minimum-32-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-minimum-32-chars
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# 📦 Storage Configuration
# Options: cloudinary
STORAGE_PROVIDER=cloudinary
# Max upload size (MB)
MAX_FILE_SIZE_MB=10

# ☁️ Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=agoge
