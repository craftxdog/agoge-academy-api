### 🏛️ Agoge Academy API - HTTP Requests

@baseUrl = http://localhost:3000/api/v1
@contentType = application/json
@organizationId = organization-id
@organizationSlug = agoge-academy

################################################

# 🔐 AUTH

################################################

### Register organization and founder

POST {{baseUrl}}/auth/register-organization
Content-Type: {{contentType}}

{
  "organizationName": "Agoge Academy",
  "organizationSlug": "{{organizationSlug}}",
  "timezone": "America/Managua",
  "locale": "es-NI",
  "currency": "NIO",
  "email": "founder@agoge.com",
  "username": "founder",
  "firstName": "Alex",
  "lastName": "Founder",
  "password": "SaaS-ready-password-2026!"
}

### Login

# @name login

POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "founder@agoge.com",
  "password": "SaaS-ready-password-2026!",
  "organizationSlug": "{{organizationSlug}}"
}

### Save token

@accessToken = {{login.response.body.data.accessToken}}

################################################

# 👤 USERS

################################################

### Get current auth context

GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

################################################

# 📊 ANALYTICS

################################################

### Get operations analytics summary

GET {{baseUrl}}/analytics/operations
Authorization: Bearer {{accessToken}}

################################################

# 🔔 NOTIFICATIONS

################################################

### Get inbox summary

GET {{baseUrl}}/notifications/summary
Authorization: Bearer {{accessToken}}

### Get historical inbox

GET {{baseUrl}}/notifications?limit=10&sortBy=createdAt&sortDirection=desc
Authorization: Bearer {{accessToken}}

### Mark one notification as read

PATCH {{baseUrl}}/notifications/notification-id/read
Authorization: Bearer {{accessToken}}

### Mark all notifications as read

PATCH {{baseUrl}}/notifications/read-all
Authorization: Bearer {{accessToken}}

################################################

# 💳 BILLING

################################################

### List payments

GET {{baseUrl}}/billing/payments?limit=10
Authorization: Bearer {{accessToken}}

################################################

# 🗓️ SCHEDULES

################################################

### Get effective day schedule

GET {{baseUrl}}/schedules/day?date=2026-05-01
Authorization: Bearer {{accessToken}}

### List locations

GET {{baseUrl}}/schedules/locations
Authorization: Bearer {{accessToken}}

################################################

# ❌ ERROR CASES (VALIDATION TESTING)

################################################

### Invalid login

POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "founder@agoge.com",
  "password": "wrongpassword"
}

### Missing token

GET {{baseUrl}}/notifications/summary

### Invalid email

POST {{baseUrl}}/auth/register-organization
Content-Type: {{contentType}}

{
  "organizationName": "Agoge Academy",
  "email": "invalid-email",
  "firstName": "Test",
  "lastName": "User",
  "password": "SaaS-ready-password-2026!"
}
